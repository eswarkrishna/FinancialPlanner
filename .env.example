# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
# Committed defaults: .env.development (dev) and .env.production (build).
# Copy this file to .env.local to override locally.
VITE_GA_MEASUREMENT_ID=

# Optional: embeddable feedback form URL (Typeform, Google Forms, etc.).
# Use the provider's embed/view URL. Leave empty to hide the form (GitHub link still shows).
# VITE_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/FORM_ID/viewform?embedded=true

# GitHub Pages subpath (set automatically in CI). Local Pages preview:
# VITE_BASE=/FinancialPlanner/

# Optional: override GitHub repo for footer commit links (owner/name).
# VITE_GITHUB_REPO=eswarkrishna/FinancialPlanner
