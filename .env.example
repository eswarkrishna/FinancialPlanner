# Optional: Discord webhook for daily alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: Telegram bot (chat id + token)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: SMTP for email alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_TO=you@example.com

# Data provider preference: openbb | yfinance | auto
DATA_PROVIDER=auto
