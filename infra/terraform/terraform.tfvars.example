# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.

# Required: globally unique S3 bucket name.
bucket_name = "financial-planner-site-CHANGE-ME"

# Optional: AWS region for the S3 origin bucket.
# CloudFront is global; ACM cert is always created in us-east-1.
aws_region = "ap-south-1"

# Optional: custom domain. Leave empty to use the default cloudfront.net URL.
# domain_name    = "planner.example.com"
# hosted_zone_id = "Z123456ABCDEFG"

# Optional: PriceClass_All (default), PriceClass_200, or PriceClass_100.
# price_class = "PriceClass_All"

# GitHub repo allowed to assume the deploy role via OIDC.
github_repo = "eswarkrishna/FinancialPlanner"

# Set to false if a GitHub OIDC provider already exists in your AWS account.
# create_github_oidc_provider = true

# Optional: enable a $1/month budget alert.
# budget_email     = "you@example.com"
# budget_limit_usd = 1
