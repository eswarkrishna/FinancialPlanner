# Copy to keystore.properties (gitignored) and fill in real values.
# Generate keystore:
#   keytool -genkey -v -keystore financial-planner-mobile.keystore \
#     -alias financial-planner -keyalg RSA -keysize 2048 -validity 10000

storeFile=/absolute/path/to/financial-planner-mobile.keystore
storePassword=your-store-password
keyAlias=financial-planner
keyPassword=your-key-password
