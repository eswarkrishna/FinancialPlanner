{
  "name": "financial-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "VITE_BASE=./ vite build",
    "cap:sync": "npm run build:mobile && npx cap sync android",
    "android:open": "npx cap open android",
    "android:assemble": "cd android && ./gradlew assembleDebug",
    "verify:android": "node scripts/verify-android-sync.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json && eslint src",
    "lint:types": "tsc --noEmit -p tsconfig.json",
    "goldens:update": "npx tsx scripts/update-goldens.ts",
    "goldens:update:us": "npx tsx scripts/update-goldens-us.ts",
    "goldens:update:uk": "npx tsx scripts/update-goldens-uk.ts",
    "test:a11y": "vitest run src/test/accessibility.test.tsx",
    "test:e2e": "tsx e2e/run.ts",
    "test:e2e:full": "npm run build && npm run test:e2e",
    "test:automation": "npm run test && npm run test:e2e:full",
    "audit:a11y": "npx tsx scripts/a11y-audit.ts",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "verify:seo": "npm run build && npx tsx scripts/verify-seo-signoff.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@fontsource/inter": "^5.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "puppeteer": "^25.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "vitest-axe": "^0.1.0"
  }
}
