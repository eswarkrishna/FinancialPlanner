{
  "name": "financial-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "goldens:update": "tsx scripts/update-goldens.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "android:sync": "npm run build && npx cap sync android",
